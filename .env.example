# Copy this file to .env and fill in your keys
# cp .env.example .env

# Google Gemini — for Imagen 4 background generation (Phase 4)
# Get free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# fal.ai — Seedance 2.0 video generation (Phase 4b)
# Get key: https://fal.ai/dashboard/keys
# Cost: ~$0.24/s fast | 4 slides × 5s ≈ $4.84 per post
FAL_KEY=

# Apify — for TikTok viral post scraping (Phase 2)
# Free tier: $5/month credits ≈ 500 posts
# Get token: https://console.apify.com → Settings → Integrations
APIFY_TOKEN=

# TikTok Content Posting API — for auto-publishing photo posts (Phase 5)
# Register app: https://developers.tiktok.com/
# Required scope: video.publish (needs app review, ~2 weeks)
# After setup, run: python3 scripts/publish_tiktok.py --auth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=   # auto-saved after running --auth
